# .env.example for Aegis XDR Ecosystem

# --- DATABASE (PostgreSQL Async) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aegis
# URL for SQLAlchemy (Must use +asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aegis

# --- CACHE & QUEUE (Redis) ---
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

# --- SERVICE PORTS ---
POSTGRES_PORT=5432
BRAIN_PORT_EXTERNAL=8000
LINK_PORT_EXTERNAL=8080

# --- SECURITY ---
# NEVER COMMIT REAL VALUES! Replace the placeholders below with your own secrets.
AEGIS_API_KEY=your_aegis_api_key_here
AGENT_ENROLL_KEY=your_enrollment_token_here
# 32-byte Base64 key for AES-256-GCM (VaultX) (e.g., generate with `openssl rand -base64 32`)
MASTER_KEY_B64=your_master_key_b64_here
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# --- OSINT API KEYS ---
SHODAN_API_KEY=your_shodan_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# --- AI SERVICES (Ollama) ---
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_DEFAULT_MODEL=llama3
AI_RATE_LIMIT_PER_MIN=10

# --- FRONTEND ---
ALLOWED_ORIGINS=http://localhost:3000

# --- AGENT DEFAULTS ---
AEGIS_AGENT_ID=agent-001
AEGIS_SCAN_INTERVAL_MS=1000
NODETRACE_DEVICE_NAME=NodeTrace-Agent
