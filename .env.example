# ─── Aegis EDR Ecosystem — Configuration ──────────────────────────────────────

# ─── DATABASE (Postgres) ───
POSTGRES_DB=aegis
POSTGRES_USER=aegis
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# URL used by aegis-brain to connect to the DB
# Inside Docker: postgresql://user:pass@aegis-postgres:5432/dbname
DATABASE_URL=postgresql://aegis:change_me@aegis-postgres:5432/aegis

# ─── CACHE & QUEUE (Redis) ───
REDIS_PORT_EXTERNAL=6379

# ─── INGESTION GATEWAY (aegis-link) ───
LINK_PORT_EXTERNAL=8080

# ─── ANALYSIS ENGINE (aegis-brain) ───
BRAIN_PORT_EXTERNAL=8000

# ─── SECURITY ───
# Shared secret for agent authentication
AEGIS_API_KEY=secret-agent-key-123

# ─── AGENT (aegis-guard) ───
# Unique ID for this agent (overridden by machine-id in native installs)
AEGIS_AGENT_ID=agent-local-01
# How often to scan for new processes (ms)
AEGIS_SCAN_INTERVAL_MS=1000
