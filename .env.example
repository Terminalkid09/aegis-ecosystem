# .env.example for Aegis XDR Ecosystem
# Copy to .env and replace every placeholder before use.

# ─── Docker Compose (recommended) ───────────────────────────────────────────
# When using `docker compose up`, service hostnames are container names.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=aegis
DATABASE_URL=postgresql+asyncpg://postgres:password@aegis-postgres:5432/aegis

REDIS_PASSWORD=replace-with-a-long-random-value
REDIS_URL=redis://:replace-with-a-long-random-value@aegis-redis:6379
REDIS_HOST=aegis-redis
REDIS_PORT=6379
REDIS_PORT_EXTERNAL=6379

# ─── Local development (services on localhost) ──────────────────────────────
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/aegis
# REDIS_URL=redis://:your_redis_password@localhost:6379
# REDIS_HOST=localhost

# ─── SERVICE PORTS ───────────────────────────────────────────────────────────
POSTGRES_PORT=5444
BRAIN_PORT_EXTERNAL=8000
LINK_PORT_EXTERNAL=8088
OLLAMA_PORT_EXTERNAL=11435

# ─── SECURITY (required — no defaults in production) ─────────────────────────
AEGIS_API_KEY=replace-with-a-long-random-value
AGENT_ENROLL_KEY=replace-with-a-long-random-value
JWT_SECRET=replace-with-at-least-32-random-characters
MASTER_KEY_B64=replace-with-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ─── OSINT API KEYS (optional) ───────────────────────────────────────────────
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=

# ─── AI (Ollama) ─────────────────────────────────────────────────────────────
OLLAMA_URL=http://aegis-ollama:11434/api/generate
OLLAMA_PORT_EXTERNAL=11435
OLLAMA_DEFAULT_MODEL=llama3
AI_RATE_LIMIT_PER_MIN=10

# ─── FRONTEND / CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── AGENT DEFAULTS ──────────────────────────────────────────────────────────
AEGIS_AGENT_ID=agent-001
AEGIS_SCAN_INTERVAL_MS=1000
NODETRACE_DEVICE_NAME=NodeTrace-Agent

